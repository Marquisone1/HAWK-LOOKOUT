# Copy this file to .env and fill in your values.
# Only WHOISFREAK_API_KEY needs to be set — everything else is auto-configured.

# ─── Optional: Flask secret key ────────────────────────────────────────────
# If blank the app auto-generates and persists a key in /data/secret_key.
# Generate manually: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ─── WhoisFreak API key ─────────────────────────────────────────────────────
# Get a key at https://whoisfreaks.com
# Can also be set (or changed) via the Settings page after logging in.
WHOISFREAK_API_KEY=

# ─── Optional runtime settings ─────────────────────────────────────────────
# FLASK_ENV is set to 'development' in docker-compose.yml so that Flask-Talisman
# does not force-redirect the internal Nginx→Gunicorn HTTP connection to HTTPS.
# Nginx handles TLS externally — do not set this to 'production' in .env.
FLASK_ENV=development
FLASK_PORT=8000

# Host port exposed by docker-compose (container still listens on 3000).
# Example: set to 8080 to access the app at http://localhost:8080
WHOIS_HOST_PORT=3000

# Optional: align container user/group IDs with your host user so ./data is
# writable without chmod 777. On Ubuntu, these are often both 1000.
APP_UID=1000
APP_GID=1000

# Set to 'false' only when running `flask run` locally without TLS.
# Leave blank (defaults to true) when deployed behind Nginx with HTTPS.
SESSION_COOKIE_SECURE=
