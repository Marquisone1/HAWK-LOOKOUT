# Copy this file to .env and fill in your values.
# Only WHOISFREAK_API_KEY needs to be set — everything else is auto-configured.

# ─── Optional: Flask secret key ────────────────────────────────────────────
# If blank the app auto-generates and persists a key in /data/secret_key.
# Generate manually: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ─── WhoisFreak API key ─────────────────────────────────────────────────────
# Get a key at https://whoisfreaks.com
# Can also be set (or changed) via the Settings page after logging in.
WHOISFREAK_API_KEY=

# ─── Optional runtime settings ─────────────────────────────────────────────
FLASK_ENV=production
FLASK_PORT=8000
